# Tokenia — environment variables
# Copy to .env and fill in values for local development.
# On Railway: set these in the Variables panel (NOT in this file).

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=Tokenia
APP_URL=https://tokenia.live
NODE_ENV=development
PORT=3000

# ── Feature flags ─────────────────────────────────────────────────────────────
# Core toggles
ENABLE_FILE_UPLOADS=true
ENABLE_PAID_FEATURES=true

# Auth (requires SUPABASE_URL + keys to be set)
ENABLE_AUTH=false

# Pro/Team features (requires auth)
ENABLE_HISTORY=true
ENABLE_PROJECTS=true

# Redis rate limiting (falls back to in-memory if false or REDIS_URL not set)
ENABLE_REDIS_RATE_LIMIT=false

# ── Billing — DISABLED (no Stripe in Phase 3) ─────────────────────────────────
# Plans are assigned MANUALLY from Supabase Dashboard.
# Never set ENABLE_BILLING=true until Stripe integration is implemented.
ENABLE_BILLING=false
ENABLE_STRIPE=false

# ── Dev overrides ─────────────────────────────────────────────────────────────
# Allow ?plan=pro query param to simulate plan tiers in development.
# Automatically disabled in production (NODE_ENV=production).
ALLOW_PLAN_QUERY_OVERRIDE=true

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── Rate limiting (baseline — further tuned per plan in code) ─────────────────
RATE_LIMIT_MAX=200
RATE_LIMIT_HEAVY_MAX=30

# ── Supabase ──────────────────────────────────────────────────────────────────
# Required when ENABLE_AUTH=true.
# Get these from: Supabase Dashboard → Settings → API
#
# SUPABASE_URL          — your project URL (e.g. https://xxx.supabase.co)
# SUPABASE_ANON_KEY     — safe to expose in browser (used for Supabase JS SDK)
# SUPABASE_SERVICE_ROLE_KEY — SECRET. Never expose. Used server-side only.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Redis ─────────────────────────────────────────────────────────────────────
# Required when ENABLE_REDIS_RATE_LIMIT=true.
# Railway: add a Redis service, it auto-sets REDIS_URL in your env.
# Upstash: copy the Redis URL from the Upstash console.
REDIS_URL=

# ── AI provider keys (optional) ───────────────────────────────────────────────
# Only needed if you enable AI-based token count verification or prompt optimization.
# Leave blank — the app works without these.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── Stripe (DO NOT SET — disabled in Phase 3) ─────────────────────────────────
# Uncomment and populate only after full Stripe integration is implemented.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRO_MONTHLY_PRICE_ID=
# STRIPE_PRO_ANNUAL_PRICE_ID=
# STRIPE_TEAM_MONTHLY_PRICE_ID=
# STRIPE_PUBLISHABLE_KEY=
