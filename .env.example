# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development        # Set "production" when deploying

# ── Feature flags ─────────────────────────────────────────────────────────────
# Unlock /api/clean and /api/retrieve (Pro features)
ENABLE_PAID_FEATURES=false

# Activate Stripe billing routes (/api/billing/checkout + /api/billing/webhook)
ENABLE_BILLING=false

# ── API key auth (optional) ───────────────────────────────────────────────────
# If set, all /api/* routes require header:  X-API-Key: <value>
# Leave empty for open access (fine for local dev)
API_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
# In production, restrict to your domain:  https://yourdomain.com
# Leave * for local dev or if serving from the same origin
CORS_ORIGIN=*

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=200          # General limit: requests per 15 min per IP
RATE_LIMIT_HEAVY_MAX=30     # Heavy routes (/api/tokenize, /api/clean, /api/retrieve)

# ── Stripe (only needed when ENABLE_BILLING=true) ─────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Get this after creating a webhook at https://dashboard.stripe.com/webhooks
# Point webhook to:  https://yourdomain.com/api/billing/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs from your Stripe product catalogue
# https://dashboard.stripe.com/products
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...
