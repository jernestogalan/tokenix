# Tokenia -- environment variables
# Copy to .env and fill in values for local development.
# On Railway: set these in the Variables panel (NOT in this file).
# NEVER commit your real .env to git.

# -- App -----------------------------------------------------------------------
APP_NAME=Tokenia
APP_URL=https://tokenia.live
NODE_ENV=development
PORT=3000

# -- Feature flags -------------------------------------------------------------
# Core toggles
ENABLE_FILE_UPLOADS=true
ENABLE_PAID_FEATURES=true

# Auth (requires SUPABASE_URL + keys to be set)
ENABLE_AUTH=false

# Pro/Team features (requires auth)
ENABLE_HISTORY=true
ENABLE_PROJECTS=true

# Redis rate limiting (falls back to in-memory if false or REDIS_URL not set)
ENABLE_REDIS_RATE_LIMIT=false

# -- Billing -- DISABLED (Stripe not yet activated) ----------------------------
# Keep both false until billing is approved and tested.
ENABLE_BILLING=false
ENABLE_STRIPE=false
# STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
# STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET
# STRIPE_PRO_MONTHLY_PRICE_ID=price_YOUR_PRICE_ID
# STRIPE_PRO_ANNUAL_PRICE_ID=price_YOUR_PRICE_ID
# STRIPE_TEAM_MONTHLY_PRICE_ID=price_YOUR_PRICE_ID

# -- Auth (Supabase) -----------------------------------------------------------
# service_role key: SERVER SIDE ONLY -- never expose in frontend or public vars
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJ_YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=eyJ_YOUR_SERVICE_ROLE_KEY   # BACKEND ONLY

# -- Redis (optional) ----------------------------------------------------------
# Leave empty to use in-memory rate limiting (fine for development / small scale)
# REDIS_URL=redis://localhost:6379

# -- Security ------------------------------------------------------------------
# Only enable in local dev -- never in production
ALLOW_PLAN_QUERY_OVERRIDE=false

# -- Credits (future) ----------------------------------------------------------
ENABLE_CREDITS=false

# -- AI optimisation (future) --------------------------------------------------
# Allow users to provide their own API key to unlock AI-assisted prompt compression
ALLOW_USER_API_KEYS=false

# -- Local embeddings (future -- NOT YET IMPLEMENTED) -------------------------
# When true, run a local sentence-transformer model instead of OpenAI embeddings.
# Currently a no-op; the retrieval route uses TF-IDF regardless of this flag.
# Set to true once the local model integration is built (Phase 5+).
USE_LOCAL_EMBEDDINGS=false
